# 0G Blockchain Configuration
ZERO_G_RPC_URL=https://rpc.0g.ai
PRIVATE_KEY=your_private_key_here

# Contract Addresses (filled after deployment)
MANAGER_ADDRESS=
VAULT_ADDRESS=
REGISTRY_ADDRESS=
UNDERLYING_ASSET=

# Mock Protocol Addresses (for demo purposes)
MOCK_AAVE_ADDRESS=0x1234567890123456789012345678901234567890
MOCK_BENQI_ADDRESS=0x2345678901234567890123456789012345678901
MOCK_COMPOUND_ADDRESS=0x3456789012345678901234567890123456789012

# 0G Compute Configuration
ZERO_G_COMPUTE_URL=https://compute.0g.ai
ZERO_G_COMPUTE_CONTRACT=
ZERO_G_ENCLAVE_KEY=

# 0G Storage Configuration
ZERO_G_STORAGE_API_KEY=demo_key
ZERO_G_STORAGE_URL=https://indexer.0g.ai

# Security Configuration
API_KEY_1=demo-key-1-change-in-production
API_KEY_2=demo-key-2-change-in-production
SIGNATURE_SECRET=demo-secret-change-in-production
SERVER_ID=autoyield-server-1

# Enterprise Key Management
AWS_REGION=us-east-1
KMS_KEY_ID=alias/autoyield-signer
KEY_PROVIDER=aws-kms
SECURE_WALLET_ADDRESS=

# Redis Configuration (for transaction queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Maximum Transaction Value (in wei)
MAX_TRANSACTION_VALUE=1000000000000000000000

# Blacklisted Addresses (comma-separated)
BLACKLISTED_ADDRESSES=
