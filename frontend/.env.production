# ========================================
# BLOCKCHAIN RPC CONFIGURATION
# ========================================
# Use paid RPC endpoints for production
VITE_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/your_alchemy_api_key

# ========================================
# DEPLOYED CONTRACT ADDRESSES
# ========================================
# Fill these after running deployUpgradeable.js
VITE_VAULT_ADDRESS=
