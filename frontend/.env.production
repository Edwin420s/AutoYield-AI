# ========================================
# API CONFIGURATION
# ========================================
# Production backend API URL
VITE_API_URL=https://api.your-domain.com/api

# ========================================
# SECURITY CONFIGURATION
# ========================================
# Enable strict network enforcement
VITE_ENFORCE_NETWORK=true

# ========================================
# 0G CONFIGURATION
# ========================================
